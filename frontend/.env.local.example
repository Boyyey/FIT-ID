# When deployed with the same host proxy on Render, use a relative API base:
# NEXT_PUBLIC_API_BASE=/api/v1
# For local development without proxying, use the full backend origin:
# NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NEXT_PUBLIC_API_BASE=hhttp://localhost:3000/api/v1
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
# Must match backend OAUTH_DEMO_CLIENT_SECRET for partner demo token exchange
# Copy the exact value from backend OAUTH_DEMO_CLIENT_SECRET
PARTNER_OAUTH_CLIENT_SECRET=replace-with-partner-oauth-client-secret