# --- Browser (Vite) — copy to .env ---
# FitID API prefix (same as main app NEXT_PUBLIC_API_BASE)
VITE_FITID_API_BASE=http://localhost:8000/api/v1
VITE_PARTNER_CLIENT_ID=fitid_demo_store
# Must match this dev server port (vite.config.ts uses 5174)
# Callback URL registered in FitID backend: http://localhost:5174/callback
VITE_TOKEN_PROXY_URL=http://localhost:8787

# Optional: paste the access_token string FitID gave you (same value as after OAuth).
# Restart `npm run dev` after editing. Only used when the browser has no saved session yet (sign out first).
# WARNING: Vite embeds this in the bundle — local / recorded demos only, never commit real tokens.
VITE_FITID_ACCESS_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJyYW1pcmhvc3NlaW44NUBnbWFpbC5jb20iLCJ0eXAiOiJmaXRpZF9wYXJ0bmVyIiwiY2lkIjoiZml0aWRfZGVtb19zdG9yZSIsInNjcCI6ImJvZHlfbWVhc3VyZW1lbnRzLGZpdF9wcmVmZXJlbmNlcyxhbGxlcmdpZXMscG9zdHVyZSxza2luX3RvbmUiLCJleHAiOjE3Nzg2OTg3MTV9.wwmZtpBFgYjU9FieN2D6h51kSyWRCKlsKuMavgvotC4
# --- Token proxy (Node) — same .env file ---
TOKEN_PROXY_PORT=8787
TOKEN_PROXY_CORS_ORIGIN=http://localhost:5174
FITID_API_BASE=http://localhost:8000/api/v1
PARTNER_OAUTH_CLIENT_ID=fitid_demo_store
PARTNER_OAUTH_CLIENT_SECRET=fitid-demo-partner-secret-change-me
