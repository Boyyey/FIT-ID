# Copy this to ".env.deploy" and fill real values before deployment.

JWT_SECRET=replace-with-long-random-secret
NEXTAUTH_SECRET=replace-with-long-random-secret

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Public URLs for deployed app:
NEXTAUTH_URL=https://app.fitid.yourdomain.com
NEXT_PUBLIC_API_BASE=https://api.fitid.yourdomain.com/api/v1
ALLOWED_ORIGINS=https://app.fitid.yourdomain.com
