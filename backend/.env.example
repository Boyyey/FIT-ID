APP_NAME=FitID API
ENVIRONMENT=development
# Local dev without Docker (default in code if unset): sqlite:///./fitid.db
# With local Postgres: postgresql+psycopg://fitid:fitid@localhost:5432/fitid
DATABASE_URL=sqlite:///./fitid.db
JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
ALLOWED_ORIGINS=https://fit-id-uzzj.onrender.com
FITID_PUBLIC_URL=https://fit-id-uzzj.onrender.com
OAUTH_DEMO_CLIENT_ID=replace-with-google-client-id
OAUTH_DEMO_CLIENT_SECRET=replace-with-oauth-demo-client-secret
OAUTH_DEMO_REDIRECT_URIS=https://fit-id-uzzj.onrender.com/partner/demo/callback,https://fit-id-uzzj.onrender.com/callback
DB_CONNECT_MAX_RETRIES=20
DB_CONNECT_RETRY_DELAY_SECONDS=1.5
