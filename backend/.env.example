APP_NAME=FitID API
ENVIRONMENT=development
# Local dev without Docker (default in code if unset): sqlite:///./fitid.db
# With local Postgres: postgresql+psycopg://fitid:fitid@localhost:5432/fitid
DATABASE_URL=sqlite:///./fitid.db
JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
GOOGLE_CLIENT_ID=replace-with-google-client-id
ALLOWED_ORIGINS=http://localhost:3000
FITID_PUBLIC_URL=http://localhost:3000
OAUTH_DEMO_CLIENT_ID=fitid_demo_store
OAUTH_DEMO_CLIENT_SECRET=fitid-demo-partner-secret-change-me
OAUTH_DEMO_REDIRECT_URIS=http://localhost:3000/partner/demo/callback,http://localhost:5174/callback
DB_CONNECT_MAX_RETRIES=20
DB_CONNECT_RETRY_DELAY_SECONDS=1.5
